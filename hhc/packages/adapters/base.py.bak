"""
Provider-agnostic adapter interface for semantic calls.

V3.1 Section 10: The semantic layer exists to handle language problems
that deterministic logic cannot. It never certifies truth by itself.

Each call is defined by:
- Input schema (what data the call receives)
- Output schema (what structured JSON it returns)
- Thinking level parameter
- Model identifier

The adapter routes to the configured provider. Swappable across
model providers without pipeline rewrite.
"""

from __future__ import annotations
from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from typing import Any, Optional


@dataclass
class SemanticCallInput:
    """Standard input for any semantic call."""
    call_type: str  # A, B, C, D, E
    data: dict      # Call-specific data
    thinking_level: str = "medium"  # minimal, low, medium, high
    max_tokens: int = 4096


@dataclass
class ExtractedClaim:
    """Output from Call A: Claim extraction."""
    claim_id: str
    claim_text: str
    claim_type: str  # factual, causal, capability, reference, conclusion
    turn_index: int
    evidence_refs: list[str] = field(default_factory=list)


@dataclass
class ClaimClassification:
    """Output from Call B: Unsupported claim detection."""
    claim_id: str
    classification: str  # supported, unsupported, insufficient_evidence, unverifiable
    rationale_span_refs: list[str] = field(default_factory=list)
    confidence: float = 0.0


@dataclass
class CapabilityClassification:
    """Output from Call C: Capability claim classification."""
    claim_id: str
    capability_type: str
    requires_runtime_proof: bool = True
    has_matching_tool_call: bool = False
    confidence: float = 0.0


@dataclass
class DriftAssessment:
    """Output from Call D: Context drift assessment."""
    drift: str  # none, minor, material
    scope_violation: bool = False
    offending_spans: list[dict] = field(default_factory=list)
    confidence: float = 0.0


@dataclass
class ContradictionResult:
    """Output from Call E: Contradiction detection."""
    claim_id: str
    contradicted_by_refs: list[str] = field(default_factory=list)
    severity: str = "medium"
    confidence: float = 0.0


@dataclass
class SemanticCallResult:
    """Standard output from any semantic call."""
    call_type: str
    success: bool
    raw_output: str = ""
    parsed: Any = None  # Will be list[ExtractedClaim], list[ClaimClassification], etc.
    model_used: str = ""
    tokens_input: int = 0
    tokens_output: int = 0
    error: Optional[str] = None


class SemanticAdapter(ABC):
    """
    Abstract adapter interface. All provider-specific logic lives here.

    Implementations must handle: API authentication, request formatting,
    response parsing, error handling, retry logic.
    """

    @abstractmethod
    async def call(self, input: SemanticCallInput) -> SemanticCallResult:
        """Execute a semantic call through the provider."""
        ...

    @abstractmethod
    def provider_name(self) -> str:
        """Return the provider name for logging."""
        ...

    @abstractmethod
    def model_for_call(self, call_type: str) -> str:
        """Return the model identifier for a given call type."""
        ...


class NoOpAdapter(SemanticAdapter):
    """
    No-op adapter for Phase 1a deterministic-only mode.
    Returns empty results without making any API calls.
    """

    async def call(self, input: SemanticCallInput) -> SemanticCallResult:
        return SemanticCallResult(
            call_type=input.call_type,
            success=True,
            raw_output="",
            parsed=None,
            model_used="none",
        )

    def provider_name(self) -> str:
        return "noop"

    def model_for_call(self, call_type: str) -> str:
        return "none"


# ────────────────────────────────────────────────
# Call contracts (input builders)
# ────────────────────────────────────────────────

def build_call_a_input(
    answer_text: str,
    context_text: str,
    turn_index: int,
) -> SemanticCallInput:
    """Build input for Call A: Claim extraction."""
    return SemanticCallInput(
        call_type="A",
        data={
            "answer_text": answer_text,
            "context_text": context_text,
            "turn_index": turn_index,
        },
        thinking_level="minimal",
    )


def build_call_b_input(
    claims: list[dict],
    evidence_snippets: list[str],
    tool_inventory: list[str],
    citation_inventory: list[str],
) -> SemanticCallInput:
    """Build input for Call B: Unsupported claim detection."""
    return SemanticCallInput(
        call_type="B",
        data={
            "claims": claims,
            "evidence_snippets": evidence_snippets,
            "tool_inventory": tool_inventory,
            "citation_inventory": citation_inventory,
        },
        thinking_level="medium",
    )


def build_call_c_input(
    capability_claims: list[dict],
    tool_call_log: list[dict],
) -> SemanticCallInput:
    """Build input for Call C: Capability claim classification."""
    return SemanticCallInput(
        call_type="C",
        data={
            "capability_claims": capability_claims,
            "tool_call_log": tool_call_log,
        },
        thinking_level="medium",
    )


def build_call_d_input(
    user_request: str,
    system_instructions: str,
    answer_text: str,
    tool_outputs: list[str],
) -> SemanticCallInput:
    """Build input for Call D: Context drift assessment."""
    return SemanticCallInput(
        call_type="D",
        data={
            "user_request": user_request,
            "system_instructions": system_instructions or "",
            "answer_text": answer_text,
            "tool_outputs": tool_outputs,
        },
        thinking_level="medium",
    )


def build_call_e_input(
    claims: list[dict],
    tool_outputs: list[str],
    cited_evidence: list[str],
) -> SemanticCallInput:
    """Build input for Call E: Contradiction detection."""
    return SemanticCallInput(
        call_type="E",
        data={
            "claims": claims,
            "tool_outputs": tool_outputs,
            "cited_evidence": cited_evidence,
        },
        thinking_level="high",
    )
